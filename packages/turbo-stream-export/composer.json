{
    "name": "turbostream/export-engine",
    "description": "High-performance Laravel package for large data exports using chunked queries and async processing",
    "type": "laravel-package",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^9.0|^10.0|^11.0",
        "league/csv": "^9.0",
        "predis/predis": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "TurboStreamExport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TurboStreamExport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TurboStreamExport\\Providers\\TurboStreamExportServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

{
    "name": "turbostream/export-engine",
    "description": "High-performance Laravel package for exporting 100M+ records using chunked queries with async processing via Redis queues. Supports CSV, Excel, PDF, DOCX, and SQL formats.",
    "type": "laravel-package",
    "license": "MIT",
    "keywords": [
        "laravel",
        "export",
        "csv",
        "excel",
        "xlsx",
        "pdf",
        "docx",
        "sql",
        "async",
        "queues",
        "redis",
        "chunked-queries",
        "large-data",
        "100m",
        "massive-export"
    ],
    "homepage": "https://github.com/turbostream/export-engine",
    "readme": "README.md",
    "time": "2026-03-19",
    "authors": [
        {
            "name": "TurboStream",
            "email": "info@turbostream.dev",
            "homepage": "https://turbostream.dev",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "support@turbostream.dev",
        "issues": "https://github.com/turbostream/export-engine/issues",
        "forum": "https://github.com/turbostream/export-engine/discussions",
        "source": "https://github.com/turbostream/export-engine"
    },
    "require": {
        "php": "^8.1",
        "laravel/framework": "^9.0|^10.0|^11.0",
        "league/csv": "^9.0",
        "predis/predis": "^2.0",
        "phpoffice/phpspreadsheet": "^1.29",
        "tecnickcom/tcpdf": "^6.6"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "TurboStreamExport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TurboStreamExport\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "test:unit": "vendor/bin/pest tests/Unit",
        "test:feature": "vendor/bin/pest tests/Feature",
        "test:large": "vendor/bin/pest tests/LargeData"
    },
    "extra": {
        "laravel": {
            "providers": [
                "TurboStreamExport\\Providers\\TurboStreamExportServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
